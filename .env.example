# Toast POS API Configuration
VITE_TOAST_CLIENT_ID=your_client_id
VITE_TOAST_CLIENT_SECRET=your_client_secret
VITE_TOAST_RESTAURANT_GUID=your_restaurant_guid

# Optional: Additional location GUIDs (comma-separated for multi-location)
VITE_TOAST_LOCATION_GUIDS=guid1,guid2

# Gemini API (if using AI features)
GEMINI_API_KEY=your_gemini_key
